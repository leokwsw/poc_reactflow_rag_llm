{
  "name": "api",
  "version": "0.1.0",
  "description": "NestJS API for RAG Workflow Studio",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
