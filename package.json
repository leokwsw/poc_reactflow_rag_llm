{
  "name": "poc-reactflow-rag-llm",
  "version": "0.1.0",
  "private": true,
  "description": "RAG Workflow Studio PoC monorepo with NestJS, Prisma, Next.js, ReactFlow, Elasticsearch and Neo4j.",
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive test",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
